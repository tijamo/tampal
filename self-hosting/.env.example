# =============================================================================
# TamFam self-hosted Supabase stack configuration.
# Copy to `.env` (same folder as docker-compose.yml) and fill in.
# Generate the secret + keys with:  node gen-keys.mjs
# =============================================================================

# --- Database -----------------------------------------------------------------
# Strong password for the Postgres service roles. Use a long random value.
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# --- JWT + API keys (from gen-keys.mjs) --------------------------------------
JWT_SECRET=change-me-run-gen-keys
ANON_KEY=run-gen-keys-to-fill-this
SERVICE_ROLE_KEY=run-gen-keys-to-fill-this

# --- URLs ---------------------------------------------------------------------
# Public URL of the API gateway (Kong), as reached by browsers. With the Caddy
# reverse proxy this is your API subdomain over HTTPS.
API_EXTERNAL_URL=https://api.tamfam.example
# Public URL of the Next.js app (used as the auth email redirect base).
SITE_URL=https://tamfam.example
# Extra allowed redirect URLs (comma-separated), e.g. for local dev.
ADDITIONAL_REDIRECT_URLS=https://tamfam.example/auth/callback,http://localhost:3000/auth/callback

# Host port Kong listens on (behind Caddy). Default 8000.
KONG_HTTP_PORT=8000

# --- SMTP (required for magic-link / invite emails) --------------------------
# Any SMTP provider works (e.g. a mailbox, SES, Postmark, Mailgun).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=postmaster@tamfam.example
SMTP_PASS=your-smtp-password
SMTP_ADMIN_EMAIL=admin@tamfam.example
SMTP_SENDER_NAME=TamFam
